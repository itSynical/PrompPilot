<!DOCTYPE html>
<html>
<head>
    <title>PromptPilot – AI Prompt Automation Hub</title>
    <link rel="stylesheet" href="[cdn.jsdelivr.net](https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css)">
</head>

<body class="bg-light">
<div class="container mt-5">
    <h1 class="mb-4">PromptPilot</h1>
    <p>Your automated hub for AI prompt insights, guides, and monetization strategies.</p>

    <a href="/generate" class="btn btn-primary mb-4">Generate New Article</a>

    <h3>Recent Posts</h3>
    <ul class="list-group">
        {% for post in posts %}
            <li class="list-group-item">
                <a href="/post/{{ post[0] }}">{{ post[1] }}</a><br>
                <small class="text-muted">{{ post[2] }}</small>
            </li>
        {% endfor %}
    </ul>
</div>
</body>
</html>
